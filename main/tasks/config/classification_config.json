{
  "_comment": "Configuration used for classification training",

  "datasets": {
    "desi-sv1": {
      "device": "cuda",
      "batch_size": 64,
      "train_ratio": 0.7,
      "val_ratio": 0.15,
      "num_epochs": 50,
      "dropout": 0.3,
      "learning_rate": 1e-4, 
      "hidden_dim": 64,
      "num_heads": 8,
      "min_delta": 1e-2,
      "stop_patience": 10,
      "lr_scheduler_patience": 5,
      "lr_scheduler_factor": 0.5,
      "default_labels": ["z"]
    }
  }
}
